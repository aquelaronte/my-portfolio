---
const currentYear = new Date().getFullYear();
---

<footer class="border-border border-t px-6 py-8 md:px-12 lg:px-24">
  <div
    class="flex max-w-4xl flex-col items-center justify-between gap-4 md:flex-row"
  >
    <p class="text-muted-foreground text-sm">
      © {currentYear} Brahian Arias. Built with{" "}
      <span class="font-display text-base"> Astro </span>{" "}
      &{" "}
      <span class="font-display text-base"> Tailwind </span>
    </p>

    <p class="text-muted-foreground font-display text-sm">
      Crafted with care from Colombia 🇨🇴
    </p>
  </div>
</footer>
