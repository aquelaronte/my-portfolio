---
import { ArrowUpRight, LockKeyhole, ChevronDown } from "lucide-react";
import { Badge } from "./ui/badge";
import { Image } from "astro:assets";
import queronTechImage from "../assets/querontech.png";

const projects = [
  {
    title: "US workers' comp insurance policy audit system",
    impact: [
      "Designed the frontend architecture for 4 separate client-facing portals, each as an independent Next.js application.",
      "Delivered UX improvements that reduced manual input errors by 45%, significantly improving the auditors' day-to-day experience.",
      "Engineered a shared commons library to orchestrate all 4 portals — centralizing UI components, utilities, and configuration to keep codebases in sync.",
      "Centralized bug fixes and feature rollouts through the commons library, eliminating duplicated work across portals.",
      "Built the GraphQL gateway from scratch to serve as the unified entry point for a distributed microservices backend.",
      "Defined the GraphQL schema and resolver layer to abstract service boundaries and simplify frontend data fetching.",
    ],
    technologies: ["Next.js", "Tailwind", "Shadcn/ui", "MongoDB", "GraphQL"],
    anon: true,
    type: "Web App",
  },
  {
    title: "CRM & Sales Analytics Platform",
    impact: [
      "Took over a non-functional application that had been rejected from the App Store and rebuilt it entirely from scratch using feature-based clean architecture.",
      "Redesigned the full project structure with a clean architecture approach, making the codebase scalable, testable, and maintainable. Also implemented testing strategies to ensure long-term reliability.",
      "Implemented real-time sales dashboards using GraphQL subscriptions, delivering live data updates to field reps without polling.",
      "Architected secure payment processing modules with hardware integration for proximity transactions.",
      "Developed low-level native bridges (Kotlin/Swift) for local network hardware discovery and secure protocol communication.",
      "Managed all Firebase storage integration for media and document handling across the app.",
    ],
    technologies: ["Flutter", "GraphQL", "Firebase", "Kotlin", "Swift"],
    anon: true,
    type: "Mobile",
  },
  {
    title: "Dating Application",
    impact: [
      "Built the full PWA from scratch, covering frontend, backend, and cloud infrastructure.",
      "Implemented geolocation-based matching algorithm and real-time chat using Supabase Realtime.",
      "Provisioned and managed cloud infrastructure on GCP with Terraform, ensuring reproducible deployments.",
      "Integrated a third-party payment provider for premium subscription processing with webhook-driven entitlement management.",
    ],
    technologies: ["Next.JS", "Tailwind", "Supabase", "GCP", "Terraform"],
    anon: true,
    type: "Web App, Backend, and Infrastructure",
  },
  {
    title: "Landing Page",
    subtitle: "Queron Technologies",
    impact: [
      "Designed and built a conversion-focused landing page for Queron Technologies.",
      "Architected a multi-step marketing funnel guiding visitors from awareness to lead capture.",
      "Set up UTM-based attribution to measure which social media campaigns drove the highest-quality leads.",
      "Configured custom conversion events and funnel drop-off reports to support ongoing A/B testing.",
    ],
    technologies: ["Next.JS", "Tailwind", "GCP"],
    type: "Web",
    url: "https://querontech.com/",
    image: queronTechImage,
  },
];

const VISIBLE_BULLETS = 4;
---

<section
  id="portfolio"
  class="border-border border-t px-6 py-20 md:px-12 lg:px-24"
>
  <div class="max-w-5xl">
    <h2 class="font-display mb-2 text-4xl md:text-5xl">Portfolio</h2>
    <p class="text-muted-foreground mb-12">
      Selected projects I&apos;ve worked on
    </p>

    <div class="grid gap-8 md:grid-cols-2">
      {
        projects.map((project, index) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="block"
          >
            <article class="group bg-card border-border hover:border-accent/50 relative overflow-hidden rounded-lg border transition-all duration-300">
              {/* Project image placeholder */}
              <div class="bg-muted relative aspect-video overflow-hidden">
                {project.image && (
                  <Image
                    src={project.image}
                    alt={project.title}
                    width={800}
                    height={450}
                    class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500"
                    onload="this.classList.remove('opacity-0')"
                    onerror="this.style.display='none'"
                  />
                )}

                <div class="absolute inset-0 flex items-center justify-center">
                  <span class="font-display text-muted-foreground/20 text-6xl">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                </div>
                {/* Decorative sketch lines */}
                <svg
                  class="absolute inset-0 h-full w-full opacity-5"
                  viewBox="0 0 400 225"
                  preserveAspectRatio="none"
                >
                  <path
                    d="M0 50 Q100 30 200 50 T400 50"
                    stroke="currentColor"
                    stroke-width="1"
                    fill="none"
                    class="stroke-foreground"
                  />
                  <path
                    d="M0 150 Q100 170 200 150 T400 150"
                    stroke="currentColor"
                    stroke-width="1"
                    fill="none"
                    class="stroke-foreground"
                  />
                </svg>
                {/* Type badge */}
                <div class="absolute top-3 left-3">
                  <Badge
                    variant="secondary"
                    className="bg-background/80 text-xs font-normal backdrop-blur-sm"
                  >
                    {project.type}
                  </Badge>
                </div>
                {/* Anonymized badge */}
                {project.anon && (
                  <div class="absolute top-3 right-3">
                    <Badge
                      variant="outline"
                      className="bg-background/80 text-xs font-normal backdrop-blur-sm flex items-center gap-1"
                    >
                      <LockKeyhole className="h-3 w-3" />
                      Client protected
                    </Badge>
                  </div>
                )}
              </div>

              {/* Content */}
              <div class="space-y-3 p-5">
                <div class="flex flex-col items-start gap-1">
                  <h3 class="group-hover:text-accent flex items-center gap-2 text-lg font-semibold transition-colors">
                    {project.title}
                    <ArrowUpRight className="h-4 w-4 opacity-0 transition-opacity group-hover:opacity-100" />
                  </h3>
                  {project.subtitle && (
                    <h2 class="text-sm">{project.subtitle}</h2>
                  )}
                </div>

                {/* Impact bullets */}
                <ul class="space-y-1.5">
                  {project.impact.map((point, i) => (
                    <li
                      class:list={[
                        "text-foreground/70 flex items-start gap-2 text-sm leading-relaxed",
                        i >= VISIBLE_BULLETS ? "impact-extra hidden" : "",
                      ]}
                    >
                      <span class="text-accent mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-current" />
                      {point}
                    </li>
                  ))}
                </ul>

                {/* See more / See less */}
                {project.impact.length > VISIBLE_BULLETS && (
                  <button
                    type="button"
                    class="see-more-btn text-muted-foreground hover:text-foreground flex items-center gap-1 text-xs transition-colors"
                  >
                    <ChevronDown className="see-more-icon h-3.5 w-3.5 transition-transform duration-200" />
                    <span class="see-more-label">See more</span>
                  </button>
                )}

                {/* Technologies */}
                <div class="flex flex-wrap gap-1.5 pt-2">
                  {project.technologies.map((tech) => (
                    <span class="text-muted-foreground bg-muted rounded px-2 py-0.5 text-xs">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>

              {/* Decorative corner */}
              <div class="absolute right-0 bottom-0 h-12 w-12 overflow-hidden opacity-0 transition-opacity group-hover:opacity-100">
                <svg viewBox="0 0 48 48" class="h-full w-full">
                  <path
                    d="M48 0 L48 48 L0 48"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1"
                    class="stroke-accent/30"
                  />
                </svg>
              </div>
            </article>
          </a>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.querySelectorAll(".see-more-btn").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      const article = btn.closest("article");
      const extras = article?.querySelectorAll(".impact-extra");
      const label = btn.querySelector(".see-more-label");
      const icon = btn.querySelector(".see-more-icon");
      const expanded = btn.getAttribute("data-expanded") === "true";

      extras?.forEach((el) => el.classList.toggle("hidden", expanded));
      btn.setAttribute("data-expanded", String(!expanded));
      if (label) label.textContent = expanded ? "See more" : "See less";
      if (icon) {
        icon.classList.toggle("rotate-180", !expanded);
      }
    });
  });
</script>
