---
import Section from "../../atoms/section.astro";
import ProjectPlaceholder from "../../atoms/project-placeholder.astro";
import dayvent from "@/assets/projects/dayvent.png";
import icewear from "@/assets/projects/ice-wear.png";

interface Project {
  name: string;
  /** Short teaser shown on the card. */
  description: string;
  /** Cover image. When omitted, a generated placeholder is shown. */
  image?: string;
  tags: string[];
  /** Concise details shown inside the dialog when the card is clicked. */
  details: string;
}

// Sample projects — replace with real work when available.
const projects: Project[] = [
  {
    name: "Dayvent",
    description:
      "Sistema de software como servicio (SaaS) para gestión de restaurantes enfocado a la rapidez e intuitividad. Con múltiples usuarios y restaurantes activos usando la aplicación bajo un modelo de suscripción mensual.",
    image: dayvent.src,
    tags: ["React", "Go", "GCP", "RPC", "PostgreSQL", "Redis"],
    details:
      "API distribuida que procesa más de 10k transacciones por minuto con latencia sub-100ms. Arquitectura orientada a eventos con colas, idempotencia y trazabilidad completa. Incluye CI/CD, observabilidad con métricas y despliegue automatizado en contenedores.",
  },
  {
    name: "Ice Wear Store",
    description:
      "Chatbot con inteligencia artificial para negocios de ropa que ayuda a los clientes a escoger prendas del catálogo según preferencias, descripciones y fotos de referencia",
    image: icewear.src,
    tags: ["Go", "PostgreSQL", "Python", "RAG", "OpenAI", "Computer Vision"],
    details:
      "API distribuida que procesa más de 10k transacciones por minuto con latencia sub-100ms. Arquitectura orientada a eventos con colas, idempotencia y trazabilidad completa. Incluye CI/CD, observabilidad con métricas y despliegue automatizado en contenedores.",
  },
  {
    name: "Go Redis Clone",
    description:
      "Clon de redis funcional hecho en go con soporte para protocolo RESP y comandos básicos para interación con la base de datos",
    tags: ["Go"],
    details:
      "Sistema RAG que conecta modelos de lenguaje con la base de conocimiento de la empresa. Pipeline de ingesta, embeddings y recuperación semántica, con evaluación de respuestas y guardarraíles. Desplegado en GCP con escalado automático y control de costos por token.",
  },
];
---

<Section class="flex-col items-start gap-12">
  <div>
    <p class="text-accent text-xs">[02] Proyectos</p>
    <h3 class="text-5xl">Algunos de mis proyectos</h3>
  </div>

  <ul class="grid w-full grid-cols-1 gap-6 md:grid-cols-2 z-20">
    {
      projects.map((project, index) => (
        <li>
          <button
            type="button"
            data-dialog-target={`project-${index}`}
            class="group flex h-full w-full cursor-pointer flex-col overflow-hidden border border-foreground/15 text-left transition duration-200 hover:border-accent/60 hover:shadow-lg hover:shadow-accent/10"
          >
            {project.image ? (
              <img
                src={project.image}
                alt={`Vista previa de ${project.name}`}
                loading="lazy"
                class="aspect-video w-full object-cover transition duration-300 group-hover:scale-105"
              />
            ) : (
              <div class="aspect-video w-full transition duration-300 group-hover:scale-105">
                <ProjectPlaceholder name={project.name} />
              </div>
            )}

            <div class="flex flex-1 flex-col gap-3 p-6">
              <h4 class="text-2xl">{project.name}</h4>
              <p class="text-sm text-foreground/80">{project.description}</p>

              <ul class="mt-auto flex flex-wrap gap-2 pt-2">
                {project.tags.map((tag) => (
                  <li class="border border-foreground/20 px-2 py-1 text-[10px] uppercase tracking-wider text-foreground/70">
                    {tag}
                  </li>
                ))}
              </ul>
            </div>
          </button>

          <dialog
            id={`project-${index}`}
            data-project-dialog
            class="m-auto w-[90vw] max-w-xl bg-background text-foreground backdrop:bg-black/70"
          >
            <div class="flex flex-col gap-5 border border-foreground/15 p-8">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-accent text-xs">Proyecto</p>
                  <h4 class="text-3xl">{project.name}</h4>
                </div>

                <button
                  type="button"
                  data-dialog-close
                  aria-label="Cerrar"
                  class="cursor-pointer text-2xl leading-none text-foreground/60 hover:text-foreground"
                >
                  &times;
                </button>
              </div>

              {project.image ? (
                <img
                  src={project.image}
                  alt={`Vista previa de ${project.name}`}
                  class="aspect-video w-full object-cover"
                />
              ) : (
                <div class="aspect-video w-full">
                  <ProjectPlaceholder name={project.name} />
                </div>
              )}

              <p class="text-sm leading-relaxed text-foreground/90">
                {project.details}
              </p>

              <ul class="flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <li class="border border-foreground/20 px-2 py-1 text-[10px] uppercase tracking-wider text-foreground/70">
                    {tag}
                  </li>
                ))}
              </ul>
            </div>
          </dialog>
        </li>
      ))
    }
  </ul>
</Section>

<script>
  // Open a project's dialog when its card is clicked, and close it via the
  // close button, the Escape key (native), or a click on the backdrop.
  const triggers = document.querySelectorAll<HTMLButtonElement>(
    "[data-dialog-target]",
  );

  triggers.forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const id = trigger.getAttribute("data-dialog-target");
      const dialog = id && document.getElementById(id);
      if (dialog instanceof HTMLDialogElement) dialog.showModal();
    });
  });

  const dialogs = document.querySelectorAll<HTMLDialogElement>(
    "[data-project-dialog]",
  );

  dialogs.forEach((dialog) => {
    // Close button.
    dialog
      .querySelector("[data-dialog-close]")
      ?.addEventListener("click", () => dialog.close());

    // Click outside the panel (on the dialog's own backdrop area).
    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });
  });
</script>
