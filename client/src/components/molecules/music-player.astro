---
interface Props {
  src?: string;
  cover?: string;
  song?: string;
  artist?: string;
  album?: string;
  year?: string | number;
  class?: string;
}

const {
  src = "/music/track.mp3",
  cover = "/music/cover.jpg",
  song = "Track title",
  artist = "Artist",
  album = "Album",
  year = "2024",
  class: className,
} = Astro.props;
---

<div
  data-player
  class:list={[
    "player fixed top-4 right-4 z-50 flex items-center gap-3 w-72 p-3 rounded-xl font-mono bg-background/60 backdrop-blur-md outline outline-foreground/15 shadow-lg shadow-black/40",
    className,
  ]}
>
  <div class="turntable shrink-0">
    <div class="vinyl">
      <span class="label">
        <img src={cover} alt={`${album} cover`} onerror="this.remove()" />
      </span>
    </div>
    <span class="tonearm"></span>
  </div>

  <div class="flex flex-col min-w-0 flex-1">
    <p class="text-xs font-bold uppercase truncate text-foreground" title={song}>
      {song}
    </p>
    <p class="text-[0.65rem] uppercase truncate text-accent" title={artist}>
      {artist}
    </p>
    <p
      class="text-[0.6rem] uppercase truncate text-foreground/60"
      title={`${album} · ${year}`}
    >
      {album} · {year}
    </p>

    <div class="flex items-center gap-2 mt-2">
      <button
        data-toggle
        type="button"
        aria-label="Play/Pause"
        class="grid place-items-center size-7 shrink-0 rounded-full bg-accent text-black cursor-pointer transition hover:scale-110"
      >
        <svg class="icon-play size-3.5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8 5v14l11-7z"></path>
        </svg>
        <svg
          class="icon-pause size-3.5"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path d="M6 5h4v14H6zm8 0h4v14h-4z"></path>
        </svg>
      </button>

      <span class="text-[0.6rem] tabular-nums text-foreground/70">
        <span data-time>0:00</span> / <span data-duration>0:00</span>
      </span>
    </div>

    <div
      data-progress-track
      class="group mt-2 h-1.5 w-full rounded-full bg-foreground/15 cursor-pointer"
    >
      <div
        data-progress-bar
        class="h-full w-0 rounded-full bg-accent transition-[width] duration-150"
      >
      </div>
    </div>

    <audio data-audio src={src} preload="metadata"></audio>
  </div>
</div>

<style>
  .turntable {
    position: relative;
    width: 5rem;
    height: 5rem;
  }

  .vinyl {
    width: 100%;
    height: 100%;
    border-radius: 9999px;
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at center, #2b2b2b 0 17%, transparent 17%),
      repeating-radial-gradient(
        circle at center,
        #0a0a0a 0 1.5px,
        #1c1c1c 1.5px 3px
      );
    box-shadow:
      0 0 0 2px #000,
      inset 0 0 8px rgba(0, 0, 0, 0.8);
    animation: vinyl-spin 3s linear infinite;
    animation-play-state: paused;
  }

  [data-player].is-playing .vinyl {
    animation-play-state: running;
  }

  .label {
    width: 42%;
    height: 42%;
    border-radius: 9999px;
    overflow: hidden;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, var(--color-accent), #4a2c39);
    border: 2px solid rgba(255, 255, 255, 0.15);
  }

  .label img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tonearm {
    position: absolute;
    top: 0.15rem;
    right: 0.55rem;
    width: 0.18rem;
    height: 3rem;
    border-radius: 9999px;
    background: linear-gradient(#e9e9e9, #8a8a8a);
    transform-origin: top center;
    /* lifted off the record */
    transform: rotate(14deg);
    transition: transform 0.45s ease;
  }

  .tonearm::after {
    /* needle head */
    content: "";
    position: absolute;
    bottom: -3px;
    left: -3px;
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    background: var(--color-accent);
  }

  [data-player].is-playing .tonearm {
    /* resting on the record */
    transform: rotate(32deg);
  }

  .icon-pause {
    display: none;
  }

  [data-player].is-playing .icon-play {
    display: none;
  }

  [data-player].is-playing .icon-pause {
    display: block;
  }

  @keyframes vinyl-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-player]").forEach((root) => {
    const audio = root.querySelector<HTMLAudioElement>("[data-audio]");
    const toggle = root.querySelector<HTMLButtonElement>("[data-toggle]");
    const timeEl = root.querySelector<HTMLElement>("[data-time]");
    const durEl = root.querySelector<HTMLElement>("[data-duration]");
    const bar = root.querySelector<HTMLElement>("[data-progress-bar]");
    const track = root.querySelector<HTMLElement>("[data-progress-track]");

    if (!audio || !toggle || !timeEl || !durEl || !bar || !track) return;

    const fmt = (s: number) => {
      if (!isFinite(s) || s < 0) return "0:00";
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60)
        .toString()
        .padStart(2, "0");
      return `${m}:${sec}`;
    };

    toggle.addEventListener("click", () => {
      if (audio.paused) audio.play();
      else audio.pause();
    });

    audio.addEventListener("play", () => root.classList.add("is-playing"));
    audio.addEventListener("pause", () => root.classList.remove("is-playing"));
    audio.addEventListener("ended", () => root.classList.remove("is-playing"));

    audio.addEventListener("loadedmetadata", () => {
      durEl.textContent = fmt(audio.duration);
    });

    audio.addEventListener("timeupdate", () => {
      timeEl.textContent = fmt(audio.currentTime);
      const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
      bar.style.width = `${pct}%`;
    });

    track.addEventListener("click", (e) => {
      if (!audio.duration) return;
      const rect = track.getBoundingClientRect();
      const ratio = Math.min(1, Math.max(0, (e.clientX - rect.left) / rect.width));
      audio.currentTime = ratio * audio.duration;
    });
  });
</script>
